# Hermes Container API Keys Configuration
# This file is mounted READ-ONLY into all containers at runtime
# Changes take effect when containers are restarted (docker restart hermes-cN)

# Default API key used for all containers (if per-container key not specified)
DEFAULT_API_KEY=hermes123456

# Per-container API keys (optional - overrides DEFAULT_API_KEY)
# Uncomment and set specific keys for individual containers:
# CONTAINER_C1_API_KEY=your_custom_key_for_c1
# CONTAINER_C2_API_KEY=your_custom_key_for_c2
# CONTAINER_C3_API_KEY=your_custom_key_for_c3
# CONTAINER_C4_API_KEY=your_custom_key_for_c4
# CONTAINER_C5_API_KEY=your_custom_key_for_c5

# Example with different keys per container:
# CONTAINER_C1_API_KEY=prod_api_key_001
# CONTAINER_C2_API_KEY=prod_api_key_002
# CONTAINER_C3_API_KEY=dev_api_key_001

# HOW TO UPDATE API KEYS:
# 1. Edit this file and change the key(s)
# 2. Stop and remove the container: docker stop hermes-c1 && docker rm hermes-c1
# 3. Respawn with new key: .\scripts\2-spawn-containers.ps1 -Count 1 -StartId 1
# Note: The data volume is preserved, so you won't lose any data!
